# =============================================================================
# Avyro — Health Journey Platform
# Environment Variables Example
#
# 1. Copy this file:  cp .env.example .env
# 2. Fill in the required values marked with
# 3. Never commit your real .env to version control
# =============================================================================

# -----------------------------------------------------------------------------
# PORTS
# -----------------------------------------------------------------------------
WEB_APP_PORT=3000
WEB_API_PORT=8000

# -----------------------------------------------------------------------------
# JWT Authentication  Required
# -----------------------------------------------------------------------------
# Generate a strong secret: openssl rand -hex 32
JWT_SECRET=your-super-secret-jwt-key-minimum-32-characters-long

JWT_ALGORITHM=HS256

# Token lifetime in minutes (1440 = 24 hours)
ACCESS_TOKEN_EXPIRE_MINUTES=1440

# -----------------------------------------------------------------------------
# MongoDB  Required
# -----------------------------------------------------------------------------
# For Docker Compose (default):
MONGO_URL=mongodb://mongo:27017/avyro

# For local development (MongoDB running on host):
# MONGO_URL=mongodb://localhost:27017/avyro

# For MongoDB Atlas:
# MONGO_URL=mongodb+srv://<user>:<password>@cluster.mongodb.net/avyro

MONGO_DB_NAME=avyro

# -----------------------------------------------------------------------------
# Stripe Payments  Required
# Get your keys at: https://dashboard.stripe.com/test/apikeys
# -----------------------------------------------------------------------------

# Backend secret key (never expose this to the client)
STRIPE_SECRET_KEY=sk_test_your_stripe_secret_key_here

# Frontend publishable key (safe to expose)
STRIPE_PUBLISHABLE_KEY=pk_test_your_stripe_publishable_key_here

# Webhook secret — get it from Stripe Dashboard → Webhooks
# For local testing use Stripe CLI: stripe listen --forward-to localhost:8000/webhook
STRIPE_WEBHOOK_SECRET=whsec_your_webhook_secret_here

# Vite frontend env (must start with VITE_ to be exposed to the browser)
VITE_STRIPE_PUBLIC_KEY=pk_test_your_stripe_publishable_key_here

# -----------------------------------------------------------------------------
# Frontend (Vite / React)
# -----------------------------------------------------------------------------
# Enable file polling for Docker on macOS/Windows (hot reload fix)
CHOKIDAR_USEPOLLING=true

# Backend API URL used by the frontend
# For Docker Compose:
VITE_API_URL=http://localhost:8000

# For production:
# VITE_API_URL=https://avyro.onrender.com
